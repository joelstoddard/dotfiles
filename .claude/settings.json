{
  "model": "opus[1m]",
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude --config ~/.config/oh-my-posh/claude.yaml",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)"
    ]
  }
}
