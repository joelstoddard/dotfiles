FROM --platform=linux/amd64 archlinux:latest

RUN echo "DisableSandbox" >> /etc/pacman.conf \
    && pacman -Syu --noconfirm \
    && pacman -S --noconfirm sudo git curl wget python python-pip stow base-devel

RUN useradd -m -s /bin/bash testuser && echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
RUN mkdir -p /home/testuser/dotfiles && chown testuser:testuser /home/testuser/dotfiles

USER testuser

# yay-bin pulls the yay binary from GitHub Releases, which occasionally 504s on
# GHA runners. makepkg retries internally (~10s window); outer loop stretches
# coverage across a ~2min window of transient errors.
RUN git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin \
    && cd /tmp/yay-bin \
    && for i in 1 2 3; do \
         makepkg -si --noconfirm && break; \
         [ "$i" -eq 3 ] && echo "yay-bin build failed after 3 attempts" && exit 1; \
         echo "yay-bin build failed (attempt $i), retrying in 30s..."; \
         sleep 30; \
       done \
    && rm -rf /tmp/yay-bin

WORKDIR /home/testuser/dotfiles

# Copy only the inputs install.sh reads so edits elsewhere (.config, theme/,
# docs) don't invalidate the install layer.
COPY --chown=testuser:testuser install.sh ./
COPY --chown=testuser:testuser scripts ./scripts
COPY --chown=testuser:testuser packages ./packages

RUN ./install.sh --yes --skip-stow --include core

COPY --chown=testuser:testuser . .
RUN .venv/bin/python scripts/verify.py || true
