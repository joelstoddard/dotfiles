FROM --platform=linux/amd64 archlinux:latest

RUN echo "DisableSandbox" >> /etc/pacman.conf \
    && pacman -Syu --noconfirm \
    && pacman -S --noconfirm sudo git curl wget python python-pip stow base-devel

RUN useradd -m -s /bin/bash testuser && echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
RUN mkdir -p /home/testuser/dotfiles-v2 && chown testuser:testuser /home/testuser/dotfiles-v2

USER testuser

RUN git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin \
    && cd /tmp/yay-bin && makepkg -si --noconfirm \
    && rm -rf /tmp/yay-bin

WORKDIR /home/testuser/dotfiles-v2
COPY --chown=testuser:testuser . .

RUN ./install.sh --yes --skip-stow --include core
RUN .venv/bin/python scripts/verify.py || true
